*.enc
credentials.*
credenciales.*
.env
.env.*

# ── Test & Debug output ──────────────────────────────────────────────────────
.debug/
export-errors.jsonl
manifest.jsonl
testdata/output/
/tmp/

# ── IDE / Editor ─────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~

# ── OS ───────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Go ───────────────────────────────────────────────────────────────────────
