# Normalize line endings to LF in repo, checkout as-is on all platforms
* text=auto eol=lf

# Go source files
*.go text eol=lf

# Markdown
*.md text eol=lf

# Config files
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.mod text eol=lf
*.sum text eol=lf

# Binaries — no line ending conversion
*.exe binary
*.enc binary
